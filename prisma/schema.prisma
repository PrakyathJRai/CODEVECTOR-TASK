generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id         String   @id @default(uuid())
  name       String
  category   String
  price      Float
  created_at DateTime
  updated_at DateTime

  @@index([created_at(sort: Desc), id(sort: Desc)])
  @@index([category, created_at(sort: Desc), id(sort: Desc)])
}